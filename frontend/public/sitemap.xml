<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <!-- Homepage -->
  <url>
    <loc>http://localhost:5000/</loc>
    <lastmod>2026-02-23</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Products Listing -->
  <url>
    <loc>http://localhost:5000/products</loc>
    <lastmod>2026-02-23</lastmod>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- Smart Deals -->
  <url>
    <loc>http://localhost:5000/deals</loc>
    <lastmod>2026-02-23</lastmod>
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
  </url>

  <!--
    Note: Individual product pages (/product/:id) are dynamic.
    For production, generate a dynamic sitemap via your Node/Express
    backend at /api/sitemap that reads from MongoDB and outputs all
    product URLs. Example endpoint structure:

    GET http://localhost:5000/api/sitemap
    → Returns XML with one <url> per product

    Then reference it as a sub-sitemap:
    <sitemap>
      <loc>http://localhost:5000/api/sitemap</loc>
    </sitemap>
  -->

</urlset>
