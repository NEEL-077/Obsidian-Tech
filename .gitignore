# Root gitignore for mobile-verse project

# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Build outputs
dist/
build/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
venv/
env/

# Database
*.db
*.sqlite

# Uploads
uploads/
temp/
